{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } }
  ],
  "routes": [
    { "src": "/manifest.json", "dest": "/manifest.json", "headers": { "Cache-Control": "public, max-age=0, must-revalidate", "Access-Control-Allow-Origin": "*" } },
    { "src": "/config.js", "dest": "/config.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/api/(.*)", "dest": "/server/index.js", "headers": { "Access-Control-Allow-Origin": "*", "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS", "Access-Control-Allow-Headers": "X-Requested-With, Content-Type, Accept, Authorization" } },
    { "src": "/socket.io/(.*)", "dest": "/server/index.js" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/asset-manifest.json", "dest": "/asset-manifest.json" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/videos/(.*)", "dest": "/videos/$1" },
    { "src": "/(.*)\\.png", "dest": "/$1.png" },
    { "src": "/(.*)\\.jpg", "dest": "/$1.jpg" },
    { "src": "/(.*)\\.svg", "dest": "/$1.svg" },
    { "src": "/(.*)\\.js", "dest": "/$1.js" },
    { "src": "/(.*)\\.css", "dest": "/$1.css" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "MONGO_URI": "mongodb+srv://dtbbuilds:dtbbuilds2025@cluster0.qnwgmty.mongodb.net/lindas-nut-butter?retryWrites=true&w=majority&appName=Cluster0",
    "PORT": "5000",
    "PRODUCTION_BASE_URL": "https://lindas-nut-butter-hweof7rg4-dtbbuilds-projects.vercel.app/api",
    "PRODUCTION_FRONTEND_URL": "https://lindas-nut-butter-hweof7rg4-dtbbuilds-projects.vercel.app",
    "MPESA_CALLBACK_URL": "https://lindas-nut-butter-hweof7rg4-dtbbuilds-projects.vercel.app/api/mpesa/callback",
    "REACT_APP_API_URL": "https://lindas-nut-butter-hweof7rg4-dtbbuilds-projects.vercel.app"
  }
}
